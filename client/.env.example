# ==========================================
# AI PPT Generator Client — Environment Variables
# ==========================================
# Copy to .env and fill in values for production deployment.
# During development, the Vite proxy handles API routing automatically.

# Backend API URL (only needed for production builds)
# Example for Render: https://your-backend-name.onrender.com
VITE_API_URL=https://your-backend-url.onrender.com
